{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Mashup-Benchmark run manifest",
  "description": "Global metadata for one baseline/method execution over one or more benchmark tasks.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "method",
    "benchmark",
    "task_file",
    "created_at",
    "status",
    "num_tasks",
    "run_outputs"
  ],
  "properties": {
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "method": {
      "type": "string",
      "minLength": 1
    },
    "method_version": {
      "type": "string"
    },
    "benchmark": {
      "const": "Mashup-Benchmark"
    },
    "task_file": {
      "type": "string",
      "description": "Path relative to benchmark root."
    },
    "created_at": {
      "type": "string"
    },
    "started_at": {
      "type": "string"
    },
    "ended_at": {
      "type": "string"
    },
    "status": {
      "enum": [
        "success",
        "partial",
        "failed",
        "running"
      ]
    },
    "num_tasks": {
      "type": "integer",
      "minimum": 0
    },
    "num_success": {
      "type": "integer",
      "minimum": 0
    },
    "num_failed": {
      "type": "integer",
      "minimum": 0
    },
    "run_outputs": {
      "type": "string",
      "description": "Path to run_outputs.jsonl, a JSONL collection of run_output records, relative to benchmark root."
    },
    "code": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "repo": {
          "type": "string"
        },
        "commit": {
          "type": "string"
        },
        "branch": {
          "type": "string"
        },
        "dirty": {
          "type": "boolean"
        }
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "platform": {
          "type": "string"
        },
        "python": {
          "type": "string"
        },
        "gpu": {
          "type": "string"
        }
      }
    },
    "config": {
      "type": "object",
      "additionalProperties": true
    },
    "aggregate": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "total_wall_clock_sec": {
          "type": "number",
          "minimum": 0
        },
        "total_api_cost_usd": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "notes": {
      "type": "string"
    }
  }
}
