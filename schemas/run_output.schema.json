{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Mashup-Benchmark per-task run output",
  "description": "One record describing the output produced by one method for one benchmark task.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "method",
    "task_id",
    "video_id",
    "audio_id",
    "prompt_type",
    "status",
    "output_video",
    "target_output_length_sec",
    "target_shot_length_sec",
    "actual_output_length_sec",
    "wall_clock_sec",
    "created_at"
  ],
  "properties": {
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "method": {
      "type": "string",
      "minLength": 1
    },
    "method_version": {
      "type": "string"
    },
    "task_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^task_[0-9]{3}$",
      "description": "Benchmark task id: task_<index>, e.g. task_001."
    },
    "video_id": {
      "type": "string",
      "minLength": 1
    },
    "audio_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^audio_[0-9]{3}$",
      "description": "Canonical audio id: audio_<index>, e.g. audio_001."
    },
    "prompt_type": {
      "enum": [
        "event",
        "character",
        "emotion",
        "narrative"
      ]
    },
    "status": {
      "enum": [
        "success",
        "failed",
        "skipped"
      ]
    },
    "output_video": {
      "type": "string",
      "description": "Path relative to the benchmark root."
    },
    "target_output_length_sec": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "target_shot_length_sec": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "actual_output_length_sec": {
      "type": "number",
      "minimum": 0
    },
    "wall_clock_sec": {
      "type": "number",
      "minimum": 0
    },
    "api_cost_usd": {
      "type": "number",
      "minimum": 0
    },
    "created_at": {
      "type": "string",
      "description": "ISO-8601 timestamp with timezone when possible."
    },
    "started_at": {
      "type": "string"
    },
    "ended_at": {
      "type": "string"
    },
    "code_commit": {
      "type": "string"
    },
    "config": {
      "type": "object",
      "additionalProperties": true
    },
    "human_scores": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "OQ": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        }
      }
    },
    "scores": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "OQ": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        }
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      },
      "properties": {
        "shot_plan": {
          "type": "string"
        },
        "backend_log": {
          "type": "string"
        },
        "run_log": {
          "type": "string"
        }
      }
    },
    "error": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "type": {
              "type": "string"
            },
            "message": {
              "type": "string"
            },
            "traceback": {
              "type": "string"
            }
          }
        }
      ]
    },
    "notes": {
      "type": "string"
    }
  }
}
